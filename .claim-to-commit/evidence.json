{
  "schemaVersion": 1,
  "project": {
    "name": "Claim to Commit",
    "description": "A local evidence workbench that audits whether software claims are backed by decisions, commits, changed files, tests, and visual proof."
  },
  "sessions": [
    {
      "id": "build-week-core",
      "label": "Build Week core session",
      "summary": "Codex and GPT-5.6 built the product contract, strict scaffold, evidence schema, Git adapters, deterministic audit engine, scan API, and reviewer-facing workbench in this continuous session.",
      "reference": "codex://build-week/current-session"
    }
  ],
  "tests": [
    {
      "id": "evidence-contract",
      "command": "npm run test:run -- tests/shared/schema.test.ts",
      "resultPath": "artifacts/test-results.json"
    },
    {
      "id": "git-evidence",
      "command": "npm run test:run -- tests/server/git-client.test.ts tests/server/validate-evidence.test.ts",
      "resultPath": "artifacts/test-results.json"
    },
    {
      "id": "audit-engine",
      "command": "npm run test:run -- tests/server/audit-claim.test.ts tests/server/audit-repository.test.ts",
      "resultPath": "artifacts/test-results.json"
    },
    {
      "id": "scan-api",
      "command": "npm run test:run -- tests/server/api.test.ts",
      "resultPath": "artifacts/test-results.json"
    },
    {
      "id": "ui-workbench",
      "command": "npm run test:run -- tests/client/App.test.tsx",
      "resultPath": "artifacts/test-results.json"
    }
  ],
